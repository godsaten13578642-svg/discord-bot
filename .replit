run = "npm start"
entrypoint = "backend/src/index.js"
modules = ["nodejs-20"]

[nix]
channel = "stable-22_11"

[[ports]]
localPort = 3001
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 5000

[userenv]

[userenv.shared]
REACT_APP_API_URL = "https://discord-bot--godsaten1357864.replit.app"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm start"
waitForPort = 5000

[agent]
expertMode = true

[deployment]
deploymentTarget = "cloudrun"
